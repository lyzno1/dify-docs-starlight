{
  "name": "dify-docs-starlight",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "sync:docs": "node scripts/sync-dify-docs.mjs",
    "sync:local": "node scripts/sync-dify-docs.mjs --local=../dify-docs",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.1",
    "astro": "^6.0.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@astrojs/check": "^0.9.6",
    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run check && pnpm run lint"
  }
}
